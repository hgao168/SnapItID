# SnapItID Configuration Template
# Copy this file to .env and fill in your values

# Cloudflare Account Configuration
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_API_KEY=your_api_key_here
CLOUDFLARE_API_TOKEN=your_api_token_here
CLOUDFLARE_ZONE_ID=your_zone_id_here

# Cloudflare Images Configuration
CLOUDFLARE_IMAGES_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_IMAGES_API_TOKEN=your_api_token_here

# Cloudflare Workers Configuration
WORKERS_ENVIRONMENT=production  # production|staging

# Application Configuration
APP_ENVIRONMENT=development  # development|staging|production
API_BASE_URL=https://api.snapitid.ai
API_TIMEOUT=30

# Feature Flags
ENABLE_COMPLIANCE_CHECK=true
ENABLE_COUNTRY_RULES=true
ENABLE_IMAGE_CACHING=true

# Logging
LOG_LEVEL=info  # debug|info|warn|error

# Database (for future phases)
# D1_DATABASE_ID=your_database_id

# Analytics (optional)
# ANALYTICS_API_KEY=your_analytics_key
