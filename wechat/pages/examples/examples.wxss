/* pages/examples/examples.wxss */

.page { padding-bottom: 60rpx; }

.section-hero {
  padding: 56rpx 32rpx 40rpx;
  text-align: center;
}

.examples-grid {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 0 24rpx;
  margin-bottom: 32rpx;
}

.example-card {
  background: #1a1a1a;
  border-radius: 20rpx;
  border: 1rpx solid rgba(255,255,255,0.08);
  overflow: hidden;
  position: relative;
}

.example-tag {
  position: absolute;
  top: 18rpx;
  left: 18rpx;
  z-index: 1;
  padding: 8rpx 20rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1.5rpx;
}
.tag-before { background: rgba(0,0,0,0.75); color: #fff; }
.tag-after  { background: #16a34a; color: #dcfce7; }

.example-img {
  width: 100%;
  height: 440rpx;
  display: block;
  background: #222;
}

.example-caption {
  display: block;
  font-size: 24rpx;
  color: #888;
  padding: 18rpx 22rpx;
}

/* cta */
.cta-block {
  margin: 0 24rpx 36rpx;
  padding: 36rpx 28rpx;
  background: linear-gradient(135deg, rgba(37,99,235,0.15), rgba(37,99,235,0.05));
  border: 1rpx solid rgba(37,99,235,0.3);
  border-radius: 20rpx;
  text-align: center;
}
.cta-text { font-size: 28rpx; color: #e8e8e8; display: block; margin-bottom: 20rpx; }
.cta-btn  { width: 80%; }

/* detail card */
.detail-card { margin: 0 24rpx; }
.detail-title { font-size: 30rpx; font-weight: 700; color: #fff; display: block; margin-bottom: 20rpx; }
.detail-list { display: flex; flex-direction: column; gap: 0; }
.detail-item {
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}
.detail-item:last-child { border-bottom: none; }
.detail-icon { font-size: 36rpx; flex-shrink: 0; }
.detail-name { font-size: 27rpx; font-weight: 600; color: #e8e8e8; display: block; }
.detail-desc { font-size: 24rpx; display: block; margin-top: 4rpx; }
