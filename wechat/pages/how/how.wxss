/* pages/how/how.wxss */

.page { padding-bottom: 60rpx; }

.section-hero {
  padding: 56rpx 32rpx 40rpx;
  text-align: center;
}

/* steps */
.steps-list { padding: 0 24rpx; display: flex; flex-direction: column; gap: 20rpx; margin-bottom: 40rpx; }

.how-card {
  background: #1a1a1a;
  border-radius: 20rpx;
  border: 1rpx solid rgba(255,255,255,0.08);
  padding: 28rpx;
  display: flex;
  gap: 22rpx;
  align-items: flex-start;
}
.how-num-badge {
  flex-shrink: 0;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(37,99,235,0.2);
  border: 1rpx solid rgba(37,99,235,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  color: #93c5fd;
}
.how-body { flex: 1; }
.how-icon { font-size: 36rpx; display: block; margin-bottom: 10rpx; }
.how-title { font-size: 30rpx; font-weight: 700; color: #fff; display: block; margin-bottom: 8rpx; }
.how-desc { font-size: 25rpx; line-height: 1.6; display: block; }

/* features */
.features-section { padding: 0 24rpx; margin-bottom: 32rpx; }
.section-inner { margin-bottom: 24rpx; }
.feat-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.feat-card {
  background: #1a1a1a;
  border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 16rpx;
  padding: 24rpx 22rpx;
  width: calc(50% - 8rpx);
  box-sizing: border-box;
}
.feat-icon { font-size: 36rpx; display: block; margin-bottom: 12rpx; }
.feat-name { font-size: 26rpx; font-weight: 700; color: #fff; display: block; margin-bottom: 8rpx; }
.feat-desc { font-size: 23rpx; display: block; line-height: 1.5; }

/* cta */
.cta-block { margin: 0 24rpx; text-align: center; }
.cta-head { font-size: 30rpx; font-weight: 700; color: #fff; display: block; margin-bottom: 20rpx; }
