/* pages/result/result.wxss */
.page { padding: 0 0 60rpx; }
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx 20rpx;
}
.header-title { font-size: 34rpx; font-weight: 700; color: #fff; }
.body { padding: 0 24rpx; }

.score-card { }
.score-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 18rpx; }
.score-label { font-size: 26rpx; color: #888; }
.score-big { font-size: 64rpx; font-weight: 800; }
.score-denom { font-size: 28rpx; font-weight: 400; color: #888; }
.score-green { color: #22c55e; }
.score-amber { color: #f59e0b; }
.score-red   { color: #ef4444; }

.score-bar-track { width: 100%; height: 12rpx; background: rgba(255,255,255,0.1); border-radius: 100rpx; overflow: hidden; margin-bottom: 18rpx; }
.score-bar-fill  { height: 100%; border-radius: 100rpx; }
.score-green.score-bar-fill { background: #22c55e; }
.score-amber.score-bar-fill { background: #f59e0b; }
.score-red.score-bar-fill   { background: #ef4444; }

.meta-row { display: flex; gap: 12rpx; flex-wrap: wrap; }

.section-h { font-size: 28rpx; font-weight: 700; color: #fff; display: block; margin-bottom: 16rpx; }

.issue-item { display: flex; gap: 14rpx; align-items: flex-start; padding: 16rpx; border-radius: 12rpx; margin-bottom: 10rpx; }
.issue-critical { background: rgba(239,68,68,0.08); border: 1rpx solid rgba(239,68,68,0.2); }
.issue-warn     { background: rgba(251,191,36,0.08); border: 1rpx solid rgba(251,191,36,0.2); }
.issue-info     { background: rgba(37,99,235,0.08);  border: 1rpx solid rgba(37,99,235,0.2); }
.issue-icon { font-size: 28rpx; flex-shrink: 0; }
.issue-desc { font-size: 26rpx; font-weight: 600; color: #e8e8e8; display: block; }
.issue-suggest { font-size: 23rpx; color: #888; display: block; margin-top: 4rpx; }

.rec-item { font-size: 25rpx; color: #c4c4c4; padding: 12rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.05); }

.mt24 { margin-top: 24rpx; }
.empty-state { text-align: center; padding: 80rpx 24rpx; }
